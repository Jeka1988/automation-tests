{
  "name": "automation-tests",
  "version": "1.0.0",
  "description": "SauceDemo automation project using Playwright + TypeScript + POM",
  "scripts": {
    "test": "playwright test",
    "test:serial": "playwright test --workers=1",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:webkit": "playwright test --project=webkit",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "typecheck": "tsc --noEmit",
    "report": "playwright show-report"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jeka1988/automation-tests.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Jeka1988/automation-tests/issues"
  },
  "homepage": "https://github.com/Jeka1988/automation-tests#readme",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  }
}
